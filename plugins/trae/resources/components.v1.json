{
  "schemaVersion": 1,
  "registryVersion": "1.1.0",
  "target": "Trae SOLO",
  "description": "Stable semantic component names and visual slots exposed to agents. Selectors remain an internal runtime detail.",
  "components": [
    {
      "id": "shell.workspace",
      "description": "Main Trae workspace and background art plane.",
      "modes": ["work", "code", "design"],
      "states": ["default"],
      "visualSlots": ["backgroundPlane", "ambientOrnament"],
      "selectors": ["#solo-lite-root", ".monaco-workbench"]
    },
    {
      "id": "mode.switcher",
      "description": "Work, Code and Design mode switcher.",
      "modes": ["work", "code", "design"],
      "states": ["default", "hover", "active", "focus"],
      "visualSlots": ["activeIndicator", "modeIcon"],
      "selectors": [".mode-switcher-btn"]
    },
    {
      "id": "sidebar.task",
      "description": "Task navigation rows, project groups and selected task.",
      "modes": ["work"],
      "states": ["default", "hover", "active", "focus", "disabled"],
      "visualSlots": ["sectionDivider", "rowIcon", "selectionMarker"],
      "selectors": [".task-list-panel", "[role=treeitem]"]
    },
    {
      "id": "sidebar.utility",
      "description": "Sidebar utility buttons such as file management and overflow.",
      "modes": ["work"],
      "states": ["default", "hover", "active", "focus", "disabled"],
      "visualSlots": ["iconContainer", "activeMark"],
      "selectors": [".taskIconBtn", "[data-trae-skin-role=sidebar-utility]"]
    },
    {
      "id": "composer.surface",
      "description": "Prompt composer, its controls, and focus ring.",
      "modes": ["work", "code"],
      "states": ["default", "hover", "focus", "disabled"],
      "visualSlots": ["edgeAccent", "toolChip", "sendAction"],
      "selectors": [".messageInputContainer", ".chat-input-v2-container", "[data-trae-skin-surface=composer]"]
    },
    {
      "id": "action.primary",
      "description": "Primary commands such as send, apply, confirm and card actions.",
      "modes": ["work", "code", "design"],
      "states": ["default", "hover", "active", "focus", "disabled"],
      "visualSlots": ["actionIcon", "fillTreatment", "motionFeedback"],
      "selectors": [".chat-input-v2-send-button", "[data-trae-skin-role=primary-action]"]
    },
    {
      "id": "message.user",
      "description": "User message content without an extra nested bubble.",
      "modes": ["work", "code"],
      "states": ["default", "hover"],
      "visualSlots": ["bubbleAccent", "cornerMark"],
      "selectors": [".turn__user-message .user-message__text-box", "[data-trae-skin-role=user-message]"]
    },
    {
      "id": "tooltip.surface",
      "description": "Tooltip portal, label, and arrow.",
      "modes": ["work", "code", "design"],
      "states": ["default"],
      "visualSlots": ["directionMark", "surfaceAccent"],
      "selectors": ["[role=tooltip]"]
    },
    {
      "id": "menu.surface",
      "description": "Menus, select portals, and popovers.",
      "modes": ["work", "code", "design"],
      "states": ["default"],
      "visualSlots": ["surfaceAccent", "sectionDivider"],
      "selectors": ["[role=menu]", "[role=listbox]", "[class*=popover-][role=dialog]"]
    },
    {
      "id": "menu.item",
      "description": "Interactive menu and select options.",
      "modes": ["work", "code", "design"],
      "states": ["default", "hover", "active", "focus", "disabled"],
      "visualSlots": ["rowIcon", "selectionMarker"],
      "selectors": ["[role=menuitem]", "[role=option]"]
    },
    {
      "id": "dialog.surface",
      "description": "Modal and non-modal dialog surfaces.",
      "modes": ["work", "code", "design"],
      "states": ["default"],
      "visualSlots": ["titleMark", "edgeAccent", "primaryAction"],
      "selectors": ["[role=dialog]"]
    },
    {
      "id": "home.title",
      "description": "New-task homepage title treatment.",
      "modes": ["work", "code", "design"],
      "states": ["default"],
      "visualSlots": ["titleMark", "underline"],
      "selectors": [".welcomeTitleWrapper", "#solo-lite-root .panel-content h1", "[data-trae-skin-role=home-title]"]
    },
    {
      "id": "home.showcase",
      "description": "New-task homepage quick actions and showcase cards.",
      "modes": ["work"],
      "states": ["default", "hover", "active", "focus"],
      "visualSlots": ["iconBadge", "cornerLabel", "cta"],
      "selectors": [".showcase-content-wrapper", "[data-trae-skin-role=showcase-card]"]
    },
    {
      "id": "home.sceneTab",
      "description": "Design homepage scene selector tabs.",
      "modes": ["design"],
      "states": ["default", "hover", "active", "focus"],
      "visualSlots": ["tabIcon", "activeIndicator"],
      "selectors": ["[data-trae-skin-role=scene-tab]"]
    },
    {
      "id": "home.scenePanel",
      "description": "Design homepage scene case panel.",
      "modes": ["design"],
      "states": ["default"],
      "visualSlots": ["panelHeader", "surfaceAccent"],
      "selectors": ["[data-trae-skin-role=scene-panel]"]
    },
    {
      "id": "home.sceneCard",
      "description": "Design homepage case card and its action.",
      "modes": ["design"],
      "states": ["default", "hover", "active", "focus"],
      "visualSlots": ["visualTile", "iconBadge", "cta"],
      "selectors": ["[data-trae-skin-role=scene-card]"]
    },
    {
      "id": "input.field",
      "description": "Text inputs and validation state.",
      "modes": ["work", "code", "design"],
      "states": ["default", "hover", "focus", "invalid", "disabled"],
      "visualSlots": ["fieldIcon", "validationMark", "focusRing"],
      "selectors": ["input", "textarea", "[role=textbox]"]
    },
    {
      "id": "selection.control",
      "description": "Checkboxes, switches and other binary controls.",
      "modes": ["work", "code", "design"],
      "states": ["default", "hover", "active", "focus", "disabled"],
      "visualSlots": ["controlTrack", "stateMark"],
      "selectors": [".arco-checkbox", ".icube-switch", "[role=checkbox]", "[role=switch]"]
    },
    {
      "id": "status.badge",
      "description": "Semantic success, warning, error and information badges.",
      "modes": ["work", "code", "design"],
      "states": ["success", "warning", "error", "info"],
      "visualSlots": ["statusIcon", "statusTint"],
      "selectors": ["[class*=status-badge]", "[data-status]"]
    },
    {
      "id": "toast.surface",
      "description": "Transient success, warning, error and information notices.",
      "modes": ["work", "code", "design"],
      "states": ["success", "warning", "error", "info"],
      "visualSlots": ["statusIcon", "edgeAccent", "dismissAction"],
      "selectors": ["[class*=toast-module__toast]", "[role=status]"]
    }
  ]
}
